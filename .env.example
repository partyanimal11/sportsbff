# Sportsball — environment variables
# Copy this file to .env.local and fill in real values.

# OpenAI — required for chat + scan
OPENAI_API_KEY=sk-...

# Supabase — required for auth + database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ... # SERVER-ONLY — never ship to client

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — required for /api/cron/build-today daily Tea feed refresh
# Generate a random string: `openssl rand -hex 32`
# Set the same value in Vercel project env vars; Vercel auto-attaches it as
# Authorization: Bearer ${CRON_SECRET} when running scheduled crons.
CRON_SECRET=

# Vercel Blob — required for stale-while-revalidate Tea feed storage.
# Auto-injected by Vercel when you enable Blob in the project settings.
# (Project → Storage → Blob → Create. Free tier covers daily writes.)
# Stores the daily Tea cards JSON so the cron can rebuild without leaving
# a cold-cache window for users.
BLOB_READ_WRITE_TOKEN=

# Replicate — face-matching API for the scan flow.
# Sign up at replicate.com, generate a token in account settings, paste here.
# Used by /api/scan/face-match to compute face embeddings via a hosted model.
# Pre-compute step runs scripts/precompute-nba-faces.ts — needs this set locally too.
# Cost: ~$0.0005 per scan. ~$0.30 one-time for the 538 NBA player pre-compute.
REPLICATE_API_TOKEN=

# Optional: override the default face-recognition model on Replicate.
# Default is a face_recognition (dlib-based) model returning 128-dim embeddings.
# If you change this, you MUST re-run scripts/precompute-nba-faces.ts so the
# pre-computed embeddings match the runtime model. Different models = different
# embedding spaces = no matches.
# REPLICATE_FACE_MODEL=owner/name:version
