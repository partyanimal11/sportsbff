# Sportsball — environment variables
# Copy this file to .env.local and fill in real values.

# OpenAI — required for chat + scan
OPENAI_API_KEY=sk-...

# Supabase — required for auth + database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ... # SERVER-ONLY — never ship to client

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — required for /api/cron/build-today daily Tea feed refresh
# Generate a random string: `openssl rand -hex 32`
# Set the same value in Vercel project env vars; Vercel auto-attaches it as
# Authorization: Bearer ${CRON_SECRET} when running scheduled crons.
CRON_SECRET=
